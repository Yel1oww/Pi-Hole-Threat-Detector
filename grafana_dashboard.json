          "query": "from(bucket: \"[YOUR_BUCKET_NAME]\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"domain_threats\")\r\n  |> filter(fn: (r) => r[\"_field\"] == \"blocked\" and (r[\"_value\"] == true or r[\"_value\"] == \"true\"))\r\n  |> group() \r\n  |> count()",
