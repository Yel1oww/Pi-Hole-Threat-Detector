        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "pulses" }]
      },
      "targets": [
        {
          "query": "from(bucket: \"[YOUR_BUCKET_NAME]\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"domain_threats\")\r\n  |> pivot(rowKey:[\"_time\", \"domain\"], columnKey: [\"_field\"], valueColumn: \"_value\")\r\n  |> group()\r\n  |> sort(columns: [\"_time\"], desc: true)\r\n  |> keep(columns: [\"_time\", \"domain\", \"blocked\", \"pulses\", \"vt_detections\"])",
          "refId": "A"
